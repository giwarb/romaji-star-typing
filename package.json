{
  "name": "romaji-star-typing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A romaji typing practice game for Japanese third graders, built with TypeScript and a Playwright AI harness.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "eval:game": "tsx scripts/evaluate-game.ts",
    "artifact:browser": "tsx scripts/capture-browser-artifact.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm run lint && npm run typecheck && npm run test && npm run eval:game && npm run build && npm run test:e2e",
    "prepare": "node scripts/install-git-hooks.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.30.0",
    "prettier": "^3.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
