{
  "name": "html-game-ai-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HTML game template with deterministic tests, Playwright autonomy harness, and GitHub Pages CI/CD.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "eval:game": "node scripts/evaluate-game.js",
    "artifact:browser": "node scripts/capture-browser-artifact.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm run lint && npm run test && npm run eval:game && npm run build && npm run test:e2e",
    "prepare": "node scripts/install-git-hooks.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.30.0",
    "prettier": "^3.6.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
